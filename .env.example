# Riffado image version. Pin to a release (e.g. `0.5.3`) for reproducible deploys.
RIFFADO_VERSION=latest

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/riffado

# Postgres password for the bundled `db` service. Default `postgres`. Changing
# this on an existing stack requires recreating the `db` volume.
# POSTGRES_PASSWORD=

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32
# Optional. Use a separate 32+ character secret if you want to rotate
# BETTER_AUTH_SECRET without invalidating API token hashes.
# API_TOKEN_HASH_SECRET=
APP_URL=http://localhost:3000

# Disable email/password registration. Default `false`.
# DISABLE_REGISTRATION=false

# Disable the footer "update available" check against api.github.com.
# DISABLE_UPDATE_CHECK=false

# Admin dashboard (hosted-only). Inert unless IS_HOSTED=true.
# ADMIN_EMAILS=ops@riffado.com,founder@riffado.com
# ADMIN_IP_ALLOWLIST=10.0.0.0/24,2001:db8::/32
# ADMIN_REAUTH_TTL_MINUTES=30
# ADMIN_MUTATION_TTL_MINUTES=10

# Optional admin subdomain. When set, the top-level middleware locks
# /admin/* and /api/admin/* to this hostname and serves them nowhere
# else (404 on the customer host). Provides cookie/blast-radius isolation
# between the customer app and admin tooling without a second deploy.
# Unset (default) keeps /admin reachable on the same host as the app,
# which is what self-host operators want. Must be a bare hostname --
# no scheme, port, or path. Must differ from APP_URL's host.
# ADMIN_HOSTNAME=admin.riffado.com

# Require public HTTPS webhook targets with DNS pinning. Defaults to IS_HOSTED.
# Set false to allow Docker-network URLs like http://n8n:5678/webhook.
# WEBHOOKS_REQUIRE_PUBLIC_TARGETS=false

# Trust X-Forwarded-For for /api/v1/* rate limiting. Only enable behind a
# trusted reverse proxy that strips client-supplied forwarding headers.
# RATE_LIMIT_TRUST_PROXY_HEADERS=false

# Encryption (for API keys, tokens, S3 credentials)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# Optional outbound proxy for Plaud API calls. Useful when the host's egress
# IP can't reach Plaud directly (geo-restriction, ISP blocking, datacenter
# IP filtering). Set this to a Webshare API key and Plaud-bound requests
# (api*.plaud.ai, resource.plaud.ai) are routed through a random valid proxy
# from your Webshare account, with automatic rotation on 403/407. Unset
# (default) sends all calls direct. No effect on non-Plaud outbound traffic.
# WEBSHARE_API_KEY=

# Proxy scope. `all` (default) proxies api*.plaud.ai and resource.plaud.ai
# audio downloads. `api-only` skips audio downloads to save proxy bandwidth.
# Inert when WEBSHARE_API_KEY is unset.
# PLAUD_PROXY_SCOPE=all

# Per-user rate limit on POST /api/plaud/sync (requests per minute).
# Default 10. Range 1..600.
# PLAUD_SYNC_RATE_LIMIT_PER_MINUTE=10

# Storage Configuration
DEFAULT_STORAGE_TYPE=local

# Local storage path. The bundled docker-compose.yml mounts the `audio` named
# volume at /app/audio and now forwards LOCAL_STORAGE_PATH into the container
# with that default, so leave this unset (or set to /app/audio) for Docker.
# For local dev outside Docker, use ./storage.
# LOCAL_STORAGE_PATH=/app/audio

# S3-compatible storage config (only needed if DEFAULT_STORAGE_TYPE=s3)
# S3_ENDPOINT=https://accountid.r2.cloudflarestorage.com
# S3_BUCKET=riffado
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Rybbit analytics (hosted-only). Both must be set together. Requires an edge
# proxy that sets X-Forwarded-For so Rybbit sees real client IPs.
# RYBBIT_SITE_ID=
# RYBBIT_HOST=https://rybbit.example.com

# SMTP Configuration (optional - for email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@example.com

# Optional separate From: for marketing/announcement-class campaigns.
# Useful when the maintainer wants product news from a personal-looking
# address while transactional mail stays on noreply@. Falls back to
# SMTP_FROM when unset.
# SMTP_MARKETING_FROM="Kacper from Riffado <kacper@riffado.com>"

# Optional Reply-To applied to every outbound email (transactional, marketing,
# and announcement). Lets From: stay a no-reply/branded sender while replies
# land in a monitored inbox. Unset means no Reply-To header is added.
# SMTP_REPLY_TO="Riffado Support <support@riffado.com>"

# Max messages per second the campaign engine emits. Default 5; range 1..100.
# Conservative default works with most commercial SMTP relays out of the box.
# EMAIL_SEND_RATE_PER_SECOND=5

# Email-verification API (Reacher / check-if-email-exists). Optional. When
# REACHER_API_KEY is unset, the pre-flight validation step is skipped and
# campaigns proceed without per-address verification -- the correct self-host
# default. Self-hosters running their own Reacher Docker container point
# REACHER_API_URL at their internal endpoint.
# REACHER_API_URL=https://check-if-email-exists.stacked.rest/v0/check_email
# REACHER_API_KEY=

# Stripe (hosted-only billing). Inert when unset. Webhook endpoint lives at
# /api/stripe/webhook -- which the hostname gate locks to ADMIN_HOSTNAME
# when set, so Stripe callbacks come into admin.riffado.com only.
#
# Key prefix selects mode: sk_test_/rk_test_ for sandbox, sk_live_/rk_live_
# for production. STRIPE_WEBHOOK_SECRET (whsec_...) verifies webhook
# signatures. Configure at least one monthly Price with STRIPE_PRICE_ID_USD
# and/or STRIPE_PRICE_ID_EUR. Annual billing is strictly additive: configure
# an annual Price id and display amount for every supported monthly currency.
# Legacy ids grant Pro if mirrored from Stripe but are never used for new
# Checkout sessions and must not duplicate current Price ids.
#
# Enable these webhook events on the endpoint (others are ignored):
# checkout.session.completed, checkout.session.expired, customer.subscription.created/updated/
# deleted/paused/resumed, invoice.paid, invoice.payment_failed.
# See docs/hosted-billing.md "First-time Stripe setup".
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_USD=price_...              # founding monthly USD
# STRIPE_PRICE_ID_EUR=price_...              # founding monthly EUR
# STRIPE_STANDARD_PRICE_ID_USD=price_...     # standard monthly USD after founding cap
# STRIPE_STANDARD_PRICE_ID_EUR=price_...     # standard monthly EUR after founding cap
# STRIPE_PRICE_ID_USD_ANNUAL=price_...
# STRIPE_PRICE_ID_EUR_ANNUAL=price_...
# STRIPE_LEGACY_PRO_PRICE_IDS=price_old_usd,price_old_eur
# Optional: inclusive VAT rate (txr_...) applied to EUR (EU/EEA)
# subscriptions so invoices show the VAT line. Match the EUR Price's
# inclusive tax_behavior (e.g. Polish 23% under the home-country/no-OSS
# model). Never applied to USD sales (non-EU export, outside EU VAT).
# STRIPE_TAX_RATE_ID_EUR=txr_...
# Pin the Customer Portal to a specific configuration (bpc_...) with
# subscription and price switching disabled. Hosted operators should not rely
# on the mutable account default portal config.
# STRIPE_PORTAL_CONFIGURATION_ID=bpc_...

# Hosted billing (Stripe). Self-host: leave BILLING_ENABLED unset.
# Requires IS_HOSTED=true, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
# at least one monthly STRIPE_PRICE_ID_USD / STRIPE_PRICE_ID_EUR,
# MYNAH_BASE_URL, and MYNAH_SERVICE_TOKEN.
# BILLING_ENABLED=true

# Mynah transcription proxy. Used as the fallback transcription provider
# for hosted users who haven't configured their own AI key. Self-host:
# leave unset. Set MYNAH_BASE_URL explicitly in hosted production instead
# of relying on a baked-in public endpoint. MYNAH_SERVICE_TOKEN is the
# shared secret with the Mynah service; both are required when
# BILLING_ENABLED=true.
# MYNAH_BASE_URL=https://mynah.example.com
# MYNAH_SERVICE_TOKEN=
# Mynah-seconds per cycle for hosted_pro (default 54000 = 15hr).
# BILLING_PRO_INCLUDED_SECONDS=54000
# Mynah-seconds per cycle for hosted_free (default 1800 = 30min free allotment).
# BILLING_FREE_INCLUDED_SECONDS=1800
# First N monthly Pro subscribers can claim founding pricing.
# Claimed slots never reopen; the benefit is forfeited when the subscription ends.
# BILLING_FOUNDING_MEMBER_CAPACITY=100
# Display prices per currency (decimal strings) -- keep in sync with the
# Stripe Prices. The Stripe Price is what actually gets charged. Founding
# monthly amounts default to 5.00; standard monthly amounts default to 9.00.
# For every configured monthly currency, annual billing requires its matching
# annual Price id and annual display amount.
# BILLING_PRICE_USD=5.00
# BILLING_PRICE_EUR=5.00
# BILLING_STANDARD_PRICE_USD=9.00
# BILLING_STANDARD_PRICE_EUR=9.00
# BILLING_PRICE_USD_ANNUAL=50.00
# BILLING_PRICE_EUR_ANNUAL=50.00
# Fallback currency when geo is unknown (usd | eur).
# BILLING_DEFAULT_CURRENCY=usd
# Request header carrying the buyer's ISO country for currency selection.
# Set to whatever the hosted LB/CDN injects; checked before the built-in
# x-vercel-ip-country / cf-ipcountry fallbacks. Unset behind a non-CDN LB
# means every buyer is billed BILLING_DEFAULT_CURRENCY.
# GEO_COUNTRY_HEADER=x-vercel-ip-country
# BILLING_PRO_INTERVAL=1 month
# BILLING_PRO_DESCRIPTION=Riffado Hosted Pro
# Trial length (days) for new hosted sign-ups. All accounts start as Pro;
# accounts without a card on file drop into trial-grace at the end.
# BILLING_TRIAL_DAYS=14
# Grace period (days) before a never-paid account is hard-deleted.
# BILLING_TRIAL_GRACE_DAYS=7
# Grace period (days) before a former-paid account is hard-deleted.
# BILLING_PAID_GRACE_DAYS=30
# Hosted billing launch date (ISO YYYY-MM-DD). Pre-launch users are
# grandfathered into the longer (paid) grace window and gates the
# grandfathered-cohort transition emails (start / reminder / ended), which
# never fire before this date.
# BILLING_LAUNCH_DATE=2026-07-01
