    `                ("webhook_deliveries"."status" = 'pending' and "webhook_deliveries"."next_attempt_at" <= $1::timestamp)\n` +
    `                or ("webhook_deliveries"."status" = 'processing' and "webhook_deliveries"."next_attempt_at" <= $2::timestamp)\n` +
    '            )\n' +
    '            and "webhook_endpoints"."enabled" = true\n' +
    '        ) ranked_deliveries\n' +
    '        where user_rank <= $3\n' +
    '        order by next_attempt_at asc, id asc\n' +
    '        limit $4\n' +
    '    ',
  params: [Array],
  [cause]: AggregateError: 
      at ignore-listed frames {
    code: 'ECONNREFUSED'
  }
}
