{
    "name": "riffado",
    "version": "0.6.2",
    "description": "Self-hosted AI transcription interface for Plaud Note devices",
    "author": "Riffado Contributors",
    "license": "AGPL-3.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/riffado/riffado.git"
    },
    "bugs": {
        "url": "https://github.com/riffado/riffado/issues"
    },
    "homepage": "https://github.com/riffado/riffado#readme",
    "keywords": [
        "plaud",
        "plaud-note",
        "transcription",
        "whisper",
        "ai",
        "self-hosted",
        "voice-recorder",
        "openai",
        "nextjs",
        "typescript"
    ],
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "postinstall": "fumadocs-mdx source.config.ts src/.source",
        "start": "next start",
        "test": "vitest run",
        "test:watch": "vitest",
        "type-check": "tsc --noEmit",
        "format-and-lint": "biome check .",
        "format-and-lint:fix": "biome check . --write",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun src/db/migrate.ts",
        "db:studio": "drizzle-kit studio",
        "release": "bun scripts/release.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1083.0",
        "@aws-sdk/lib-storage": "^3.1083.0",
        "@aws-sdk/s3-request-presigner": "^3.1083.0",
