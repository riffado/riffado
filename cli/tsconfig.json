{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "allowImportingTsExtensions": false,
        "types": ["node"]
    },
    "include": [
        "src/**/*.ts",
        "tests/**/*.ts",
        "tsup.config.ts",
        "vitest.config.ts"
    ],
    "exclude": ["dist", "node_modules"]
}
